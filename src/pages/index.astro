---
import Layout from '../layouts/Layout.astro';
---
<Layout title="HESI Patient Reviews">
  <section style="text-align:center; padding: 4rem 1rem;">
    <h1 style="font-size:2.5rem; font-weight:700; margin-bottom:1rem;">HESI Patient Reviews</h1>
    <p style="font-size:1.2rem; color:#555; max-width:600px; margin:0 auto 2rem;">
      A collection of nursing case studies designed to help students prepare for
      HESI exams through realistic patient review scenarios.
    </p>
    <a
      href={`${import.meta.env.BASE_URL}case-studies`}
      style="display:inline-block; background:#1a1a2e; color:#fff; padding:0.75rem 1.75rem; border-radius:6px; text-decoration:none; font-weight:600; font-size:1rem;"
    >
      Browse Case Studies
    </a>
  </section>
</Layout>
